# GitHub Pages : le workflow CI définit VITE_BASE_PATH automatiquement.
# En local, pour tester comme sur Pages : VITE_BASE_PATH=/nom-de-ton-repo/

# Copie ce fichier en .env et remplis les valeurs depuis Firebase Console
# (Paramètres du projet → Tes applications → SDK Web)

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
